---
import Layout from '~/layouts/Layout.astro';

// Plausible auto-tracks pageviews. To measure waitlist conversion, configure
// a goal in the Plausible dashboard for "Pageview /products/mirage-lumen-thanks".
// Conversion rate = thanks-page views / Lumen-page views.
---

<Layout
  title="You're on the Mirage Lumen waitlist"
  description="You're on the Mirage Lumen waitlist. We'll email when it ships."
  canonical="https://mirageinteractive.uk/products/mirage-lumen-thanks"
  noIndex={true}
>
  <main class="container-page py-20">
    <a href="/" class="text-sm text-ink-400 hover:text-white">&larr; Home</a>

    <div class="mt-10 max-w-2xl">
      <span class="eyebrow">Mirage Lumen</span>
      <h1 class="mt-6 font-display text-4xl font-bold text-white sm:text-5xl">You're on the list.</h1>
      <p class="mt-6 text-ink-200">We'll email you when Mirage Lumen ships. No other mail. You can request deletion any time at <a href="mailto:legal@mirageinteractive.uk" class="text-mi-200 hover:text-white">legal@mirageinteractive.uk</a>.</p>
      <p class="mt-8"><a href="/products/mirage-lumen" class="text-mi-200 hover:text-white">&larr; Back to Mirage Lumen</a></p>
    </div>
  </main>
</Layout>
