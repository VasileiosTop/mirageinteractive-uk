---
import Layout from '~/layouts/Layout.astro';
---

<Layout
  title="Mirage Lumen — Offline dental dictation for clinicians"
  description="Offline dental dictation for clinicians. Your spoken notes, transcribed into your own templates — entirely on your device. No audio, no text, nothing leaves. Join the waitlist."
  canonical="https://mirageinteractive.uk/products/mirage-lumen"
>
  <main class="container-page py-20">
    <a href="/" class="text-sm text-ink-400 hover:text-white">&larr; Home</a>

    <div class="mt-10">
      <span class="eyebrow">In development</span>
      <h1 class="mt-6 font-display text-4xl font-bold text-white sm:text-5xl">Mirage Lumen</h1>
      <p class="mt-3 text-mi-200">Offline dental dictation for clinicians.</p>
    </div>

    <div class="mt-10 max-w-2xl space-y-5 text-ink-200">
      <p>Your spoken notes, transcribed into your own templates — entirely on your device. No audio, no text, nothing leaves.</p>
      <p>In development for iOS and Android. Join the waitlist to be notified when it ships.</p>
    </div>

    <form
      method="POST"
      action="/api/waitlist/lumen"
      class="mt-10 max-w-md space-y-4"
    >
      <div>
        <label for="email" class="block text-sm text-ink-300">Email</label>
        <input
          type="email"
          id="email"
          name="email"
          required
          maxlength="254"
          autocomplete="email"
          placeholder="you@example.com"
          class="mt-2 w-full rounded-md border border-ink-800 bg-ink-950/40 px-3 py-2 text-sm text-white placeholder:text-ink-500 focus:border-mi-300 focus:outline-none"
        />
      </div>

      <div class="hidden" aria-hidden="true">
        <label for="website">Website</label>
        <input type="text" id="website" name="website" tabindex="-1" autocomplete="off" />
      </div>

      <button type="submit" class="btn-primary">Join the waitlist</button>

      <p class="text-xs text-ink-500">
        Email only. No tracking. Delete anytime by emailing <a href="mailto:legal@mirageinteractive.uk" class="text-mi-200 hover:text-white">legal@mirageinteractive.uk</a>.
      </p>
    </form>
  </main>
</Layout>
