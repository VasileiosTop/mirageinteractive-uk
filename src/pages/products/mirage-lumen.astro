---
import Layout from '~/layouts/Layout.astro';

const productSchema = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Mirage Lumen',
  description:
    'Offline dental dictation for clinicians. Voice notes transcribed on-device into customisable templates. Audio and text never leave the device.',
  applicationCategory: 'BusinessApplication',
  operatingSystem: 'iOS, Android',
  url: 'https://mirageinteractive.uk/products/mirage-lumen',
  publisher: {
    '@type': 'Organization',
    name: 'Mirage Interactive Ltd',
    url: 'https://mirageinteractive.uk',
  },
};

const faq = [
  {
    q: 'Will it work without internet?',
    a: "Yes. Once installed, Lumen runs entirely on your device. The internet is only needed to download updates or templates we publish, both of which you can opt out of.",
  },
  {
    q: 'Is this a medical device?',
    a: 'No. Lumen is a productivity tool, not a medical device. It does not diagnose, treat, or replace clinical judgement. Clinicians remain responsible for the accuracy of their records.',
  },
  {
    q: 'What happens to my notes if I lose my phone?',
    a: "Your notes are protected by your device passcode and the platform's storage encryption (iOS Data Protection or Android FBE). We add nothing on top because we never see the notes.",
  },
  {
    q: 'Can I bring my own templates?',
    a: 'Yes. Templates are local files, editable in plain text. Lumen does not impose a structure.',
  },
  {
    q: "How do you make money if you don't see any data?",
    a: 'A subscription at launch. Pricing will be published when Lumen ships.',
  },
  {
    q: 'Why dental specifically?',
    a: "Dental notes are short, structured, and consistent enough to be a good fit for on-device language models. Broader general-medicine notes need cloud-scale models that don't yet fit on a phone.",
  },
  {
    q: 'When will it ship?',
    a: 'In development. Join the waitlist for the launch email — we will not email you for any other reason.',
  },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faq.map((item) => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: { '@type': 'Answer', text: item.a },
  })),
};
---

<Layout
  title="Mirage Lumen — Offline dental dictation for clinicians"
  description="Offline dental dictation for clinicians. Your spoken notes, transcribed into your own templates — entirely on your device. No audio, no text, nothing leaves. Join the waitlist."
  canonical="https://mirageinteractive.uk/products/mirage-lumen"
>
  <main class="container-page py-20">
    <a href="/" class="text-sm text-ink-400 hover:text-white">&larr; Home</a>

    <div class="mt-10">
      <span class="eyebrow">In development</span>
      <h1 class="mt-6 font-display text-4xl font-bold text-white sm:text-5xl">Mirage Lumen</h1>
      <p class="mt-3 text-mi-200">Offline dental dictation for clinicians.</p>
    </div>

    <div class="mt-10 max-w-2xl space-y-5 text-ink-200">
      <p>Your spoken notes, transcribed into your own templates — entirely on your device. No audio, no text, nothing leaves.</p>
      <p>In development for iOS and Android. Join the waitlist to hear when it ships.</p>
    </div>

    <form
      id="waitlist"
      method="POST"
      action="/api/waitlist/lumen"
      class="mt-10 max-w-md space-y-4"
    >
      <div>
        <label for="email" class="block text-sm text-ink-300">Email</label>
        <input
          type="email"
          id="email"
          name="email"
          required
          maxlength="254"
          autocomplete="email"
          placeholder="you@example.com"
          class="mt-2 w-full rounded-md border border-ink-800 bg-ink-950/40 px-3 py-2 text-sm text-white placeholder:text-ink-400 focus:border-mi-300 focus:outline-none"
        />
      </div>

      <div class="hidden" aria-hidden="true">
        <label for="website">Website</label>
        <input type="text" id="website" name="website" tabindex="-1" autocomplete="off" />
      </div>

      <button type="submit" class="btn-primary">Join the waitlist</button>

      <p class="text-xs text-ink-500">
        Email only. No tracking. Delete anytime by emailing <a href="mailto:legal@mirageinteractive.uk" class="text-mi-200 hover:text-white">legal@mirageinteractive.uk</a>.
      </p>
    </form>

    <section class="mt-20 max-w-2xl">
      <span class="eyebrow">What it does</span>
      <h2 class="mt-4 font-display text-3xl font-bold text-white">Three things, one place.</h2>
      <ol class="mt-8 space-y-6 text-ink-200">
        <li>
          <strong class="font-semibold text-white">Dictate.</strong>
          Speak naturally. Lumen transcribes and applies the structure you usually write in — SOAP, FDI charting, perio chart, or one of your own templates.
        </li>
        <li>
          <strong class="font-semibold text-white">Edit.</strong>
          Touch up the transcript before saving. Voice-driven corrections, no menu-diving.
        </li>
        <li>
          <strong class="font-semibold text-white">Export.</strong>
          Copy out as plain text or a structured snippet ready for your practice software. Nothing is stored unless you save it.
        </li>
      </ol>
    </section>

    <section class="mt-20 max-w-2xl">
      <span class="eyebrow">Templates</span>
      <h2 class="mt-4 font-display text-3xl font-bold text-white">Your shape, not ours.</h2>
      <ul class="mt-8 space-y-3 text-ink-200">
        <li><strong class="font-semibold text-white">SOAP</strong> — subjective, objective, assessment, plan.</li>
        <li><strong class="font-semibold text-white">FDI charting</strong> — international tooth notation.</li>
        <li><strong class="font-semibold text-white">Perio chart</strong> — periodontal pocket depths and recession.</li>
        <li><strong class="font-semibold text-white">Custom</strong> — bring your own. Templates are local files, editable in plain text.</li>
      </ul>
    </section>

    <section class="mt-20">
      <span class="eyebrow">Privacy &amp; data</span>
      <h2 class="mt-4 font-display text-3xl font-bold text-white">What goes where.</h2>
      <div class="mt-8 overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-ink-800">
              <th class="py-3 pr-4 text-left font-semibold text-white">Data</th>
              <th class="py-3 text-left font-semibold text-white">Leaves your device?</th>
            </tr>
          </thead>
          <tbody class="text-ink-200">
            <tr class="border-b border-ink-800/60">
              <td class="py-3 pr-4">Audio recordings</td>
              <td class="py-3">No. Audio is processed on-device and never uploaded.</td>
            </tr>
            <tr class="border-b border-ink-800/60">
              <td class="py-3 pr-4">Transcribed text</td>
              <td class="py-3">No. Notes stay local until you choose to copy them out.</td>
            </tr>
            <tr class="border-b border-ink-800/60">
              <td class="py-3 pr-4">Templates</td>
              <td class="py-3">No. Stored locally.</td>
            </tr>
            <tr class="border-b border-ink-800/60">
              <td class="py-3 pr-4">Crash reports</td>
              <td class="py-3">Anonymous, opt-in only. No content of notes is ever included.</td>
            </tr>
            <tr>
              <td class="py-3 pr-4">Usage analytics</td>
              <td class="py-3">None. The app does not phone home.</td>
            </tr>
          </tbody>
        </table>
      </div>
    </section>

    <section class="mt-20 max-w-2xl">
      <span class="eyebrow">Regulatory posture</span>
      <h2 class="mt-4 font-display text-3xl font-bold text-white">A productivity tool, not a medical device.</h2>
      <p class="mt-6 text-ink-200">
        Mirage Lumen does not diagnose, treat, or replace clinical judgement. Clinicians remain responsible for the accuracy of their records. We are not currently UKCA or CE-marked because the product does not meet the definition of a medical device under MDR or UK MDR 2002.
      </p>
    </section>

    <section class="mt-20 max-w-2xl">
      <span class="eyebrow">Hardware</span>
      <h2 class="mt-4 font-display text-3xl font-bold text-white">Recent phones.</h2>
      <p class="mt-6 text-ink-200">
        Optimised for recent iPhones and Android devices. Exact minimum requirements will be published when Lumen ships.
      </p>
    </section>

    <section class="mt-20">
      <span class="eyebrow">Compared with existing tools</span>
      <h2 class="mt-4 font-display text-3xl font-bold text-white">Where your patient's voice ends up.</h2>
      <div class="mt-8 overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-ink-800">
              <th class="py-3 pr-4 text-left font-semibold text-white"></th>
              <th class="py-3 pr-4 text-left font-semibold text-white">Mirage Lumen</th>
              <th class="py-3 pr-4 text-left font-semibold text-white">Heidi</th>
              <th class="py-3 pr-4 text-left font-semibold text-white">Suki</th>
              <th class="py-3 text-left font-semibold text-white">Nuance Dragon</th>
            </tr>
          </thead>
          <tbody class="text-ink-200">
            <tr class="border-b border-ink-800/60">
              <td class="py-3 pr-4 font-semibold text-white">Audio processed</td>
              <td class="py-3 pr-4">On your device</td>
              <td class="py-3 pr-4">Their cloud</td>
              <td class="py-3 pr-4">Their cloud</td>
              <td class="py-3">Their cloud</td>
            </tr>
            <tr class="border-b border-ink-800/60">
              <td class="py-3 pr-4 font-semibold text-white">Internet required</td>
              <td class="py-3 pr-4">No (after install)</td>
              <td class="py-3 pr-4">Yes</td>
              <td class="py-3 pr-4">Yes</td>
              <td class="py-3">Yes</td>
            </tr>
            <tr class="border-b border-ink-800/60">
              <td class="py-3 pr-4 font-semibold text-white">Dental-specific templates</td>
              <td class="py-3 pr-4">Yes</td>
              <td class="py-3 pr-4">Limited</td>
              <td class="py-3 pr-4">Limited</td>
              <td class="py-3">Limited</td>
            </tr>
            <tr>
              <td class="py-3 pr-4 font-semibold text-white">Pricing model</td>
              <td class="py-3 pr-4">Subscription, TBD at launch</td>
              <td class="py-3 pr-4">Subscription</td>
              <td class="py-3 pr-4">Subscription</td>
              <td class="py-3">Subscription</td>
            </tr>
          </tbody>
        </table>
      </div>
      <p class="mt-6 max-w-xl text-sm text-ink-400">
        These are the obvious search competition for AI clinical dictation. We're naming them because honesty matters more than positioning. If we've got something wrong, tell us at <a href="mailto:contact@mirageinteractive.uk" class="text-mi-200 hover:text-white">contact@mirageinteractive.uk</a>.
      </p>
    </section>

    <section class="mt-20 max-w-3xl">
      <span class="eyebrow">FAQ</span>
      <h2 class="mt-4 font-display text-3xl font-bold text-white">Common questions.</h2>
      <dl class="mt-10 space-y-8">
        {faq.map((item) => (
          <div>
            <dt class="font-display text-lg font-semibold text-white">{item.q}</dt>
            <dd class="mt-3 text-ink-200">{item.a}</dd>
          </div>
        ))}
      </dl>
    </section>

    <section class="mt-20 max-w-2xl">
      <p class="text-ink-200">
        Want it? <a href="#waitlist" class="text-mi-200 hover:text-white">Join the waitlist</a> at the top.
      </p>
    </section>

    <script type="application/ld+json" set:html={JSON.stringify(productSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </main>
</Layout>
